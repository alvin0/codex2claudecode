{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // Test files use terse inline doubles such as fetch mocks; source typecheck remains strict.
    "noImplicitAny": false
  },
  "include": [
    "index.ts",
    "scripts/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "test/**/*.ts",
    "test/**/*.tsx"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
