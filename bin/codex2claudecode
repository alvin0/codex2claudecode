#!/usr/bin/env node
import { spawnSync } from "node:child_process"
import { dirname, join } from "node:path"
import { fileURLToPath } from "node:url"

const root = dirname(fileURLToPath(import.meta.url))
const entry = join(root, "..", "dist", "index.js")
const args = [entry, ...process.argv.slice(2)]
const result = spawnSync("bun", args, { stdio: "inherit", env: process.env })

if (result.error?.code === "ENOENT") {
  console.error("codex2claudecode requires Bun to run.")
  console.error("")
  console.error("Install Bun first:")
  console.error("  macOS/Linux: curl -fsSL https://bun.sh/install | bash")
  console.error("  Windows PowerShell: powershell -c \"irm bun.sh/install.ps1 | iex\"")
  console.error("")
  console.error("Then run again:")
  console.error("  npx codex2claudecode")
  process.exit(1)
}

if (result.error) {
  console.error(result.error.message)
  process.exit(1)
}

process.exit(result.status ?? 0)
