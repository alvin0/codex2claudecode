#!/usr/bin/env bun
import { parseCliOptions } from "../src/cli.ts"
import { runExample, startRuntime } from "../src/index.ts"
import { runUi } from "../src/ui/index.tsx"

const options = parseCliOptions()

Promise.resolve(process.env.CODEX_RUN_EXAMPLE === "1" ? runExample() : process.env.CODEX_NO_UI === "1" ? startRuntime({ port: options.port }) : runUi(options)).catch((error) => {
  console.error(error)
  process.exit(1)
})
