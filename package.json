{
  "name": "codex2claudecode",
  "version": "0.1.3",
  "author": "alvin0 <chaulamdinhai@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/alvin0/codex2claudecode#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alvin0/codex2claudecode.git"
  },
  "bugs": {
    "url": "https://github.com/alvin0/codex2claudecode/issues"
  },
  "type": "module",
  "bin": {
    "codex2claudecode": "./bin/codex2claudecode"
  },
  "files": [
    "bin",
    "images",
    "src",
    "index.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "bun index.ts",
    "dev": "bun --watch index.ts",
    "example": "CODEX_RUN_EXAMPLE=1 bun index.ts",
    "check": "bun build index.ts --target=bun --outfile=/tmp/codex2claudecode.js",
    "test": "bun test test/*.test.ts --test-name-pattern='^(?!.*live Codex smoke test)'",
    "coverage": "bun test test/*.test.ts --test-name-pattern='^(?!.*live Codex smoke test)' --coverage --coverage-reporter=text",
    "test:live": "CODEX_AUTH_FILE=auth-codex.json bun test test/live.test.ts"
  },
  "dependencies": {
    "ink": "^7.0.1",
    "react": "^19.2.5",
    "react-devtools-core": "^7.0.1"
  }
}
